{
  "name": "kubehealer",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev",
  "dev:web": "pnpm --filter @kubehealer/web dev",
  "dev:agent": "pnpm --filter @kubehealer/agent dev",
  "dev:supertonic": "./scripts/start-supertonic-tts.sh",
    "build": "pnpm --filter @kubehealer/shared build && pnpm run -r build",
    "typecheck": "pnpm run -r typecheck",
    "lint": "pnpm run -r lint"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}

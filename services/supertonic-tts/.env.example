# Hugging Face token (optional for public models; required for gated assets or higher rate limits)
HF_TOKEN=
HUGGING_FACE_HUB_TOKEN=

# Supertonic model (default: supertonic-3 from Supertone/supertonic-3)
SUPERTONIC_MODEL=supertonic-3
# SUPERTONIC_MODEL_REPO=Supertone/supertonic-3

# Cache directory for downloaded ONNX weights (~400MB on first run)
# SUPERTONIC_CACHE_DIR=~/.cache/supertonic3

# Voice preset: M1–M5 (male), F1–F5 (female). Default M1.
SUPERTONIC_VOICE=M1

# ISO 639-1 language code (en, ko, ja, …) or "na" for unknown. Default en.
SUPERTONIC_LANG=en

# ONNX execution providers (comma-separated). Auto-detects GPU if unset.
# Examples:
#   CUDAExecutionProvider,CPUExecutionProvider
#   CoreMLExecutionProvider,CPUExecutionProvider
# SUPERTONIC_ONNX_PROVIDERS=CUDAExecutionProvider,CPUExecutionProvider

# Thread tuning (optional)
# SUPERTONIC_INTRA_OP_THREADS=
# SUPERTONIC_INTER_OP_THREADS=

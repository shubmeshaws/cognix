{
  "name": "@kubehealer/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:in-cluster": "node dist/in-cluster/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "create-admin": "tsx --env-file=.env scripts/create-admin.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.0.4",
    "@fastify/websocket": "^11.0.2",
    "@kubehealer/shared": "workspace:*",
    "@kubernetes/client-node": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.34.8",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}

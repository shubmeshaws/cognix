# KubeHealer agent — local dev (pnpm dev:agent)
# Copy: cp apps/agent/.env.example apps/agent/.env

# ── Required ────────────────────────────────────────────────────────────────
# Postgres via `docker compose up -d postgres` listens on host port 5433
DATABASE_URL=postgresql://kubehealer:kubehealer@localhost:5433/kubehealer
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
# Default Ollama URL (Settings → Agent can override without editing this file)
OLLAMA_URL=http://localhost:11434

# ── Optional — server / dev ─────────────────────────────────────────────────
PORT=3001
MAX_MEMORY_LIMIT=4Gi
# Dev: read ~/.kube/config via GET /api/clusters/local-kubeconfig
ALLOW_LOCAL_KUBECONFIG=false
# LOG_LEVEL=info

# ── Optional — configure in Settings → Agent instead (recommended) ────────
# LLM keys, models, and provider chain are saved to .kubehealer/llm-config.json
# when you click Apply in the dashboard. Env vars below are fallbacks only.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# PUTER_AUTH_TOKEN=
# PUTER_APP_ORIGIN=http://localhost:3000

# ── Optional — heal escalation webhooks ─────────────────────────────────────
# SLACK_WEBHOOK_URL=
# PAGERDUTY_INTEGRATION_KEY=

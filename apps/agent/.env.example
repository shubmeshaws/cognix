DATABASE_URL=postgresql://kubehealer:kubehealer@localhost:5432/kubehealer
REDIS_URL=redis://localhost:6379
OLLAMA_URL=http://localhost:11434
# Optional — used when Ollama is unavailable
OPENAI_API_KEY=
# Optional — Claude / Anthropic API key
ANTHROPIC_API_KEY=
# Optional — Puter.js auth token (https://puter.com/dashboard)
PUTER_AUTH_TOKEN=
# Origin bound to Puter sign-in (defaults to http://localhost:3000)
PUTER_APP_ORIGIN=http://localhost:3000
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
PORT=3001
# Dev: read ~/.kube/config via GET /api/clusters/local-kubeconfig
ALLOW_LOCAL_KUBECONFIG=false
MAX_MEMORY_LIMIT=4Gi
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=

# Set to true to skip login and open the dashboard directly (local dev only)
NEXT_PUBLIC_AUTH_DISABLED=true
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER=smtp://user:pass@localhost:1025
# Optional cloud TTS fallback (when local Supertonic is offline)
HF_TTS_MODEL=facebook/mms-tts-eng

# Local Supertonic 3 TTS (Supertone/supertonic-3) — start with ./scripts/start-supertonic-tts.sh
SUPERTONIC_TTS_URL=http://127.0.0.1:7788
SUPERTONIC_LANG=en
SUPERTONIC_VOICE_FEMALE=F1
SUPERTONIC_VOICE_MALE=M1
# Auto-start Supertonic when Neural AI Voice is toggled on (local dev)
SUPERTONIC_AUTO_START=true

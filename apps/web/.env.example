# Cognix web — local dev (pnpm dev:web)
# Copy: cp apps/web/.env.example apps/web/.env

# ── Required ────────────────────────────────────────────────────────────────
# Browser/API calls from the dashboard (use EC2 public IP when accessing remotely).
NEXT_PUBLIC_API_URL=http://localhost:3001
# Server-side /setup proxy → agent on loopback (required on EC2; do not use public IP here).
AGENT_INTERNAL_URL=http://127.0.0.1:3001
# Must match apps/agent JWT_SECRET (signs agent API tokens)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# ── Optional ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Auth (required for setup wizard → admin → login flow) ───────────────────
# Set NEXT_PUBLIC_AUTH_DISABLED=true only to skip login and go straight to dashboard.
NEXT_PUBLIC_AUTH_DISABLED=false
NEXTAUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# EMAIL_SERVER=smtp://user:pass@localhost:1025
# EMAIL_FROM=Cognix <noreply@cognix.local>

# ── Meshy voice TTS (defaults work; start with ./scripts/start-supertonic-tts.sh)
# SUPERTONIC_TTS_URL=http://127.0.0.1:7788
# SUPERTONIC_LANG=en
# SUPERTONIC_VOICE_FEMALE=F1
# SUPERTONIC_VOICE_MALE=M1
# SUPERTONIC_AUTO_START=true
# HF_TTS_MODEL=facebook/mms-tts-eng
